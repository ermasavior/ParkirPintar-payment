APP_PORT=8086
APP_NAME=payment-service
APP_ENV=local
LOG_LEVEL=info
LOG_FORMAT=json

POSTGRES_DSN=postgres://<user>:<password>@localhost:5432/parkir_pintar?sslmode=disable

NATS_URL=nats://localhost:4222

# HTTP port for the inbound payment gateway webhook
WEBHOOK_PORT=8087
# Shared secret used to verify HMAC-SHA256 webhook signatures
WEBHOOK_SECRET=<your-webhook-secret>

# Base URL of the payment gateway (stub or real)
GATEWAY_STUB_URL=http://localhost:8088

# OpenTelemetry — leave empty to disable
OTEL_SERVICE_NAME=parkirpintar-payment
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_METRIC_EXPORT_INTERVAL=60
OTEL_BLRP_SCHEDULE_DELAY=60
